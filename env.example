# MiniMax (Anthropic-compatible API) configuration.
# Copy to .env and fill in your key:  cp env.example .env
#
# The anthropic SDK reads ANTHROPIC_BASE_URL and ANTHROPIC_API_KEY automatically.
# International platform endpoint (use https://api.minimaxi.com/anthropic for the China platform):
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Your MiniMax API key (https://platform.minimax.io -> API Keys):
ANTHROPIC_API_KEY=your_minimax_api_key_here

# Model the scenarios run against (overrides the claude-sonnet-4-6 default):
MODEL=MiniMax-M3
